# ============================================================
# Multi-Agent Productivity Assistant — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.

# Google Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Project ID (for BigQuery)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# BigQuery Dataset name (will be created by the setup script)
BIGQUERY_DATASET=productivity_assistant

# Server port (Cloud Run expects 8080)
PORT=8080
