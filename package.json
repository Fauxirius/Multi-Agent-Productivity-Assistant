{
  "name": "multi-agent-productivity-assistant",
  "version": "1.0.0",
  "description": "A multi-agent AI system for managing tasks, schedules, and information using Google Gemini, BigQuery, and MCP",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test:demo": "npx ts-node scripts/generate_walkthrough.ts",
    "setup:bq": "bq query --use_legacy_sql=false < setup/bigquery_schema.sql"
  },
  "keywords": [
    "multi-agent",
    "gemini",
    "bigquery",
    "mcp",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.1",
    "@google/genai": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "@types/uuid": "^10.0.0",
    "playwright": "^1.51.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
